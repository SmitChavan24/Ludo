# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` (it is gitignored).
# ──────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed browser origins (CORS).
# In dev this is the Vite client. In prod, your real domain(s).
CLIENT_ORIGINS=http://localhost:5174

# ── JWT signing secrets ──
# Generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Use DIFFERENT secrets for access and refresh tokens.
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ACCESS_TTL=900            # access token lifetime, seconds (15 min)
JWT_REFRESH_TTL=2592000       # refresh token lifetime, seconds (30 days)

# ── Google Sign-In ──
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web).
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Admin / CRM API ──
# Shared secret your CRM sends as the `x-admin-key` header (server-to-server).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank to disable the API-key path.
ADMIN_API_KEY=

# Admin WEB PAGE login at http://localhost:4000/admin (JWT-protected).
# Set a password to enable the page; leave blank to disable web login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_JWT_TTL=1800           # admin session length, seconds (30 min)

# ── Dev-only login ──
# When "true" AND NODE_ENV=development, allows a passwordless dev login
# endpoint for local testing without Google. MUST be false in production.
ALLOW_DEV_LOGIN=true

# ── Storage backend ──
# 'memory' (default) keeps everything in RAM and resets on restart.
# 'mysql' persists users, coins, and game history. Set up a DB + user, e.g.:
#   CREATE DATABASE coinludo CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER 'coinludo'@'%' IDENTIFIED BY 'your-password';
#   GRANT ALL PRIVILEGES ON coinludo.* TO 'coinludo'@'%';
# Tables are created automatically on startup.
DB_DRIVER=memory
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=coinludo
DB_PASSWORD=
DB_NAME=coinludo
DB_POOL=10

# ── Game economy ──
SIGNUP_BONUS_COINS=1000       # free coins a new account starts with
DAILY_BONUS_COINS=100         # coins for a daily login
RAKE_BIPS=500                 # platform fee in basis points (500 = 5%)
TURN_TIMEOUT_MS=30000         # auto-skip a player's turn after this long
